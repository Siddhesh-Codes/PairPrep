# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pairprep

# JWT — MUST be at least 32 characters, change in production!
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters

# App
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated origins (optional, defaults to FRONTEND_URL)
# CORS_ORIGINS=https://pairprep.vercel.app,http://localhost:3000
